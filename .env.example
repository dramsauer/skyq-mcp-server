# ---------------------------------------------------------------------------
# Sky Q receiver connection
# ---------------------------------------------------------------------------

# IP address of your Sky Q box (required)
SKYQ_HOST=192.168.1.99

# Control port (default 49160 — only change if your network is unusual)
SKYQ_PORT=49160

# JSON API port (default 9006)
SKYQ_JSON_PORT=9006

# EPG cache size (default 20 channels)
SKYQ_EPG_CACHE_LEN=20

# ---------------------------------------------------------------------------
# Safety — write/mutation tools
# ---------------------------------------------------------------------------

# Set to true to allow remote-control key presses, channel changes,
# and recording deletion.  Disabled by default so assistants cannot
# accidentally modify your receiver state.
SKYQ_ALLOW_MUTATIONS=false

# ---------------------------------------------------------------------------
# HTTP server
# ---------------------------------------------------------------------------

SERVER_HOST=0.0.0.0
SERVER_PORT=8000
